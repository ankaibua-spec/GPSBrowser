<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ data extraction rules - exclude all sensitive prefs from backup/transfer -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="gpsbrowser.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="gpsbrowser.xml" />
    </device-transfer>
</data-extraction-rules>
